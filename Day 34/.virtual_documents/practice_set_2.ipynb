#8 create a calculator

def calc(a, b, op):
    match op:
        case "+":
             return a+b
        case "-":
             return a-b
        case "*":
             return a*b
        case "/":
            if b == 0:
                print("Devided by 0 is not possible.")
            else:    
                return a/b
        case _: 
            print("Operation not supported!")

a = int(input("Enter number 1: "))
b = int(input("Enter number 2: "))
op = input("Enter operator: ")

calc(a, b, op)          


#9 find Prime Number

def is_prime(n):
    if n < 2: return False
    if n == 2: return True    
    if n % 2 == 0: return False 
    
    for i in range(3, int(n**0.5) + 1, 2): 
        if n % i == 0:
            return False
    return True

print(is_prime(9))  
print(is_prime(13)) 


