area = 22/7*r*r
print(area)


#9 Calculate simple interest. 

P = float(input("Enter principle: "))
R = float(input("Enter Rate of Interest (annual): "))
T = float(input("Enter Time (annual): "))

I = (P*R*T)/100
print(I)


