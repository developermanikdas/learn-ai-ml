   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"globalAirQuality.csv\")\n",
    "df.head()\n",
    "\n",
    "df.loc[0:9]\n",
    "\n",
    "df.iloc[0:8, 3:8]\n",
    "\n",
    "df.at[0, \"aqi\"]\n",
    "\n",
    "\n",
    "# aqi > 100\n",
    "\n",
    "df.loc[(df[\"aqi\"] > 100) & (df[\"temperature\"] > 30)][[\"country\", \"city\", \"aqi\"]]"
   ]
  },
