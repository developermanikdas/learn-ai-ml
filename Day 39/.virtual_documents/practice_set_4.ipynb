#3 Create a class with some private keys And use getter and setter functions 

class Student:
    def __init__(self, name, roll_no, marks):
        # We call the setters here so validation logic isn't duplicated!
        self.set_name(name)
        self.set_roll_no(roll_no)
        self.set_marks(marks)

    # --- Name Getter & Setter ---
    def get_name(self):
        return self._name

    def set_name(self, value):
        if not value or value.strip() == "":
            raise ValueError("Name cannot be empty.")
        self._name = value

    # --- Roll Number Getter & Setter ---
    def get_roll_no(self):
        return self._roll_no

    def set_roll_no(self, value):
        if 1 <= value <= 100:
            self._roll_no = value
        else:
            raise ValueError("Roll number has to be between 1 & 100.")

    # --- Marks Getter & Setter ---
    def get_marks(self):
        return self._marks

    def set_marks(self, value):
        if value < 0:
            raise ValueError("Marks cannot be negative.")
        self._marks = value

# Testing the implementation
try:
    s1 = Student("Alice", 45, 85)
    print(f"Student: {s1.get_name()}, Roll: {s1.get_roll_no()}, Marks: {s1.get_marks()}")
    
    # This will trigger the validation
    s1.set_marks(-10) 
except ValueError as e:
    print(f"Error: {e}")


#4 Function Overriding

import math
from abc import ABC, abstractmethod

class Shape:   
    @abstractmethod
    def area(self):
        return 0
        
class Circle(Shape):
    def __init__(self, radius):
        self.radius = radius
    def area(self):
        return math.pi * (self.radius**2)

        
class Rectangle(Shape):
    def __init__(self, length, width):
        self.length = length
        self.width = width
    def area(self):
        return self.length * self.width

class Triangle(Shape):
    def __init__(self, height, base):
        self.height = height
        self.base = base
    def area(self):
        return .5 * self.height * self.base    
        
   
shapes = [Circle(7), Rectangle(10,5), Triangle(10,5)]

for s in shapes:
    print(f"{s.area():.2f}")


#5 Inheritance

class Vehicle:
    def __init__(self, brand, model):
        self.brand = brand
        self.model = model
        
class Car(Vehicle):
    def __init__(self, brand, model, seats):
        super().__init__(brand, model)
        self.seats = seats 
class Bike(Vehicle):
    def __init__(self, brand, model, engine_cc):
        super().__init__(brand, model)
        self.engine_cc = engine_cc 

Car("Tata", "Nano", 4).seats        
Bike("Tata", "Nano", 1000).engine_cc        


#6 Abstraction

from abc import ABC, abstractmethod

class Employee(ABC):
    @abstractmethod
    def calculate_salary(self):
        pass

class Intern(Employee):
    def calculate_salary(self):
        return 20_000
        
class FullTimeEmployee(Employee):
    def calculate_salary(self):
        return 40_000

class ContractEmployee(Employee):
    def calculate_salary(self):
        return 60_000

# Assigning instances to variables and printing the output
i1 = Intern()
print(f"Intern Salary: ${i1.calculate_salary():,}")

f1 = FullTimeEmployee()
print(f"Full-Time Salary: ${f1.calculate_salary():,}")

c1 = ContractEmployee()
print(f"Contract Salary: ${c1.calculate_salary():,}")


#7 Constructor Overloading (with Default Parameters)

class Person:
    def __init__(self, name, age=None, address=None):
        self.name = name
        self.age = age
        self.address = address
        
    def display_info(self):
        info = f"Name = {self.name} "

        if self.age is not None:
            info += f"Age = {self.age}, "
        if self.address is not None:
            info += f"Address = {self.address}"    

        print(info)
        
# 1. Name only
person1 = Person("Alice")
person1.display_info()

# 2. Name + Age
person2 = Person("Bob", 30)
person2.display_info()

# 3. Name + Age + Address
person3 = Person("Charlie", 25, "123 Main St")
person3.display_info()        


