import requests
from bs4 import BeautifulSoup

page_count = 1
is_page_over = False
data_list = []

while not is_page_over:
    URL = f"https://quotes.toscrape.com/page/{page_count}/"
    res = requests.get(URL)
    
    if res.status_code == 200:
        soup = BeautifulSoup(res.text, "lxml")
        quote_list = soup.find_all("div", class_="quote")

        # CRITICAL: If no quotes are found, we've hit the end of the site
        if not quote_list:
            print(f"No more quotes found. Stopping at page {page_count}.")
            is_page_over = True
            break

        print(f"Scraping page {page_count}...")

        for quote in quote_list:
            # We use a list comprehension to get all tags for this specific quote
            tags = [tag.text for tag in quote.find_all("a", class_="tag")]
            
            if "life" in tags:
                text = quote.find("span", class_="text").text   
                author = quote.find("small", class_="author").text
                data_list.append({"author": author, "text": text})
        
        page_count += 1
    else:
        is_page_over = True

print(f"\nSuccessfully scraped {len(data_list)} quotes about 'life'.")
print(data_list)



