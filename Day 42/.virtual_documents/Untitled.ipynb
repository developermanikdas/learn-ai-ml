np.zeros((3,4))
np.ones((3,4))
np.empty((3,4), dtype="int16")

np.arange(10, 31, 5)
np.arange(0, 2.1, 0.3)  # it accepts float arguments


np.linspace(0, 2, 9)                   # 9 numbers from 0 to 2
